<Window x:Class="ItMaster.Desktop.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IT-Master Desktop (WPF)" Height="820" Width="1360" WindowStartupLocation="CenterScreen">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#F2F2F2" Padding="10">
            <StackPanel>
                <TextBlock x:Name="HeaderTextBlock" FontWeight="Bold" FontSize="14"/>
                <TextBlock x:Name="AccessTextBlock" Foreground="DimGray" FontSize="12"/>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Left" Width="230" Background="#F5F7FA" Padding="8">
            <StackPanel>
                <Button Content="Расписание" Click="OpenSchedule_OnClick" Margin="0,0,0,6"/>
                <Button Content="Тесты" Click="OpenTests_OnClick" Margin="0,0,0,6"/>
                <Button Content="Статистика тестов" Click="OpenTestStats_OnClick" Margin="0,0,0,6"/>
                <Button Content="Уведомления" Click="OpenNotifications_OnClick" Margin="0,0,0,6"/>
                <Button Content="Заявки" Click="OpenOrders_OnClick" Margin="0,0,0,6"/>
                <Button Content="Инвентарь" Click="OpenInventory_OnClick" Margin="0,0,0,6"/>
                <Button Content="Wiki" Click="OpenWiki_OnClick" Margin="0,0,0,6"/>
                <Button Content="Пользователи и роли" Click="OpenUsersRoles_OnClick" Margin="0,0,0,6"/>
                <Button Content="Настройки" Click="OpenSettings_OnClick" Margin="0,0,0,6"/>
                <Button Content="Выйти" Click="Logout_OnClick" Background="#E15656" Foreground="White" Margin="0,14,0,0"/>
            </StackPanel>
        </Border>

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="GlobalStatusTextBlock" Margin="0,0,0,8" Foreground="DarkSlateGray"/>

            <TabControl x:Name="ModulesTabControl" Grid.Row="1">
                <TabItem Header="Расписание">
                    <Grid Margin="8">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <DatePicker x:Name="ScheduleWeekPicker" Width="150"/>
                            <Button Content="Обновить" Margin="8,0,0,0" Click="ScheduleRefresh_OnClick"/>
                        </StackPanel>
                        <DataGrid x:Name="ScheduleGrid" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True"/>
                    </Grid>
                </TabItem>

                <TabItem Header="Тесты">
                    <Grid Margin="8">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="2*"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBox x:Name="TestsSearchBox" Width="220" TextChanged="TestsSearchBox_OnTextChanged"/>
                            <Button Content="Обновить" Margin="8,0,0,0" Click="TestsRefresh_OnClick"/>
                            <Button Content="Начать попытку" Margin="8,0,0,0" Click="TestsStart_OnClick"/>
                            <Button x:Name="TestsSubmitButton" Content="Отправить ответы" Margin="8,0,0,0" Click="TestsSubmit_OnClick"/>
                        </StackPanel>
                        <DataGrid x:Name="TestsGrid" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True" SelectionChanged="TestsGrid_OnSelectionChanged"/>
                        <DataGrid x:Name="TestQuestionsGrid" Grid.Row="2" AutoGenerateColumns="True" IsReadOnly="True"/>
                    </Grid>
                </TabItem>

                <TabItem Header="Статистика тестов">
                    <Grid Margin="8">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ComboBox x:Name="StatsGroupCombo" Width="240"/>
                            <TextBox x:Name="StatsPageBox" Width="60" Margin="8,0,0,0" Text="1"/>
                            <Button Content="Загрузить" Margin="8,0,0,0" Click="StatsLoad_OnClick"/>
                        </StackPanel>
                        <DataGrid x:Name="StatsGrid" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True"/>
                    </Grid>
                </TabItem>

                <TabItem Header="Уведомления">
                    <Grid Margin="8">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBox x:Name="NotificationsSearchBox" Width="220" TextChanged="NotificationsSearchBox_OnTextChanged"/>
                            <Button Content="Обновить" Margin="8,0,0,0" Click="NotificationsRefresh_OnClick"/>
                        </StackPanel>
                        <DataGrid x:Name="NotificationsGrid" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True"/>
                    </Grid>
                </TabItem>

                <TabItem Header="Заявки">
                    <Grid Margin="8">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ComboBox x:Name="OrdersCategoryCombo" Width="220"/>
                            <TextBox x:Name="OrdersRoomBox" Width="120" Margin="8,0,0,0"/>
                            <TextBox x:Name="OrdersDescriptionBox" Width="300" Margin="8,0,0,0"/>
                            <Button Content="Создать" Margin="8,0,0,0" Click="OrdersCreate_OnClick"/>
                            <Button Content="Обновить" Margin="8,0,0,0" Click="OrdersRefresh_OnClick"/>
                            <ComboBox x:Name="OrdersStatusSetCombo" Width="120" Margin="8,0,0,0"/>
                            <Button Content="Применить статус" Margin="8,0,0,0" Click="OrdersSetStatus_OnClick"/>
                        </StackPanel>
                        <DataGrid x:Name="OrdersGrid" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True"/>
                    </Grid>
                </TabItem>

                <TabItem Header="Инвентарь">
                    <Grid Margin="8">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBox x:Name="InventorySearchBox" Width="220" TextChanged="InventorySearchBox_OnTextChanged"/>
                            <Button Content="Обновить" Margin="8,0,0,0" Click="InventoryRefresh_OnClick"/>
                        </StackPanel>
                        <DataGrid x:Name="InventoryGrid" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True"/>
                    </Grid>
                </TabItem>

                <TabItem Header="Wiki">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="340"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,8,8">
                            <TextBox x:Name="WikiSearchBox" Width="180" TextChanged="WikiSearchBox_OnTextChanged"/>
                            <Button Content="Обновить" Margin="8,0,0,0" Click="WikiRefresh_OnClick"/>
                        </StackPanel>
                        <DataGrid x:Name="WikiGrid" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True" SelectionChanged="WikiGrid_OnSelectionChanged"/>
                        <TextBox x:Name="WikiBodyBox" Grid.Column="1" Grid.RowSpan="2" Margin="10,0,0,0" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True"/>
                    </Grid>
                </TabItem>

                <TabItem Header="Пользователи и роли">
                    <Grid Margin="8">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="Обновить все" Click="UsersRolesRefresh_OnClick"/>
                        </StackPanel>
                        <TabControl Grid.Row="1">
                            <TabItem Header="Сотрудники"><DataGrid x:Name="EmployeesGrid" AutoGenerateColumns="True" IsReadOnly="True"/></TabItem>
                            <TabItem Header="Роли"><DataGrid x:Name="RolesGrid" AutoGenerateColumns="True" IsReadOnly="True"/></TabItem>
                            <TabItem Header="Группы"><DataGrid x:Name="GroupsGrid" AutoGenerateColumns="True" IsReadOnly="True"/></TabItem>
                        </TabControl>
                    </Grid>
                </TabItem>

                <TabItem Header="Настройки">
                    <Grid Margin="8">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Название сайта"/>
                        <TextBox x:Name="SettingsTitleBox" Grid.Row="1" Margin="0,6,0,10"/>
                        <TextBlock Grid.Row="2" Text="Причина отключения"/>
                        <TextBox x:Name="SettingsReasonBox" Grid.Row="3" Margin="0,6,0,10" AcceptsReturn="True" Height="100"/>
                        <StackPanel Grid.Row="4" Orientation="Horizontal">
                            <CheckBox x:Name="SettingsEnabledCheck" Content="Сайт включен"/>
                            <Button Content="Загрузить" Margin="8,0,0,0" Click="SettingsLoad_OnClick"/>
                            <Button Content="Сохранить" Margin="8,0,0,0" Click="SettingsSave_OnClick"/>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
