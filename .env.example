APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Продакшен (ваш домен): APP_URL=https://axobeast.ru

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
# Рекомендуется true для продакшена (шифрование содержимого сессии).
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
# В продакшене за HTTPS должно быть true.
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# SMTP TLS policy (recommended false in production):
# true = allow insecure/self-signed TLS certs for SMTP
MAIL_SMTP_ALLOW_INSECURE_TLS=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Версия релиза в интерфейсе (semver), например 1.0.0. Иначе: файл VERSION в корне или поле "release" в storage/app/deploy.json
# APP_RELEASE_VERSION=1.0.0

# Проверка обновлений с GitHub, если на сервере нет git clone (см. storage/app/deploy.json: ref, опционально release)
DEPLOY_GITHUB_REPO=axobeasty/it2
DEPLOY_GITHUB_BRANCH=master
# DEPLOY_GITHUB_TOKEN=
# DEPLOY_GIT_REF=

# Путь к PHP CLI для «Обновить из Git» (после pull выполняется php artisan migrate). Если не задан — команда php из PATH или PHP_BINARY (не php-fpm).
# PHP_CLI=/usr/bin/php8.2
